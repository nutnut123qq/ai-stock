# --- LangGraph POST /api/analyze ---
# LLM_PROVIDER: ollama (default) | gemini | blackbox | openrouter
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_BASE_URL=http://127.0.0.1:11434
# GOOGLE_API_KEY= (when LLM_PROVIDER=gemini)
# GEMINI_MODEL=gemini-2.5-flash
# BLACKBOX_API_KEY= (when LLM_PROVIDER=blackbox)
# OPENROUTER_API_KEY= (when LLM_PROVIDER=openrouter; model mặc định: openrouter/free)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openrouter/free

# .NET StockInvestment.Api — news + technical context for /api/analyze
BACKEND_BASE_URL=http://localhost:5197
# Same as appsettings AnalystContext:ApiKey (X-Internal-Api-Key). Omit if server key is empty.
BACKEND_INTERNAL_API_KEY=

# --- Former ai-service (summarize, RAG, forecast batch, …) ---
# See src/shared/config.py for full list; common vars:
BLACKBOX_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=stock_documents
RABBITMQ_CONNECTION_STRING=amqp://guest:guest@localhost:5672/
INTERNAL_API_KEY=
API_TITLE=Stock Investment AI Service
API_VERSION=1.0.0
CORS_ORIGINS=*

# Optional infra (used by some jobs / docs)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stock_investment
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
REDIS_HOST=localhost
REDIS_PORT=6379
ENVIRONMENT=development

# .NET: point AIService:BaseUrl (and optional StockAnalyst:BaseUrl) to this app, e.g. http://localhost:8000

# --- Financial report Q&A (dashboard) ---
# Backend calls POST /api/qa with base_context + source=financial_report. Run this service, e.g.:
#   uvicorn src.api.main:app --reload --port 8000
# LLM: set GEMINI_API_KEY (preferred) or BLACKBOX_API_KEY in this .env — same stack as forecast/news QA.
# StockInvestment.Api: AIService:BaseUrl (and Url) = http://localhost:8000 (or Docker host, e.g. http://host.docker.internal:8000).
# Qdrant errors are OK: .NET sends the full report snapshot in base_context; QAService can skip vector search for financial_report when base_context is present.

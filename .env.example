# --- LangGraph POST /api/analyze ---
# LLM_PROVIDER: ollama (default) | gemini | blackbox | openrouter | beeknoee
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5:1.5b
OLLAMA_BASE_URL=http://127.0.0.1:11434
# GOOGLE_API_KEY= (when LLM_PROVIDER=gemini)
# GEMINI_MODEL=gemini-2.5-flash
# BLACKBOX_API_KEY= (when LLM_PROVIDER=blackbox)
# OPENROUTER_API_KEY= (when LLM_PROVIDER=openrouter; model mặc định: openrouter/free)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=openrouter/free
# OpenRouter free-tier rate limiting (default 18 req/min window, 3.5s base delay)
# OPENROUTER_RPM_LIMIT=18
# OPENROUTER_BASE_DELAY=3.5
# Beeknoee (OpenAI-compatible): https://platform.beeknoee.com — key dạng sk-bee-...
# BEEKNOEE_API_KEY=
# BEEKNOEE_BASE_URL=https://platform.beeknoee.com/api/v1
# BEEKNOEE_MODEL=glm-4.7-flash
# BEEKNOEE_TIMEOUT=120
# Optional: skip /api/analyze pre-flight LLM ping when using Beeknoee (avoids 1 concurrent slot issues).
# BEEKNOEE_SKIP_LLM_PROBE=true
# Optional pause (seconds) after each Beeknoee completion inside LangGraph (default 0.8).
# BEEKNOEE_LLM_COOLDOWN_SEC=0.8
# When Beeknoee returns 429, honour the provider's Retry-After hint and retry once inside the lock (default on).
# BEEKNOEE_RESPECT_RETRY_AFTER=true
# Hard cap on the Retry-After sleep so a slow 429 can't block the HTTP request for too long.
# BEEKNOEE_MAX_RETRY_AFTER_SEC=30
# IMPORTANT: Beeknoee free tier allows only 1 concurrent request per API key.
# The serialization lock in src/infrastructure/llm/beeknoee_sync.py is in-process,
# so you MUST run uvicorn with a single worker when LLM_PROVIDER=beeknoee, e.g.:
#   uvicorn main:app --host 127.0.0.1 --port 8000 --workers 1
# Multi-worker setups require a distributed lock (Redis) instead.

# .NET StockInvestment.Api — news + technical context for /api/analyze
BACKEND_BASE_URL=http://localhost:5197
# Same as appsettings AnalystContext:ApiKey (X-Internal-Api-Key). Omit if server key is empty.
BACKEND_INTERNAL_API_KEY=

# --- Former ai-service (summarize, RAG, forecast batch, …) ---
# See src/shared/config.py for full list; common vars:
BLACKBOX_API_KEY=
OPENROUTER_API_KEY=
BEEKNOEE_API_KEY=
GEMINI_API_KEY=
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=stock_documents
RABBITMQ_CONNECTION_STRING=amqp://guest:guest@localhost:5672/
INTERNAL_API_KEY=
API_TITLE=Stock Investment AI Service
API_VERSION=1.0.0
CORS_ORIGINS=*

# Optional infra (used by some jobs / docs)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stock_investment
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
REDIS_HOST=localhost
REDIS_PORT=6379
# Dedicated DB index for Python AI service (.NET backend uses DB 0 by convention)
REDIS_DB=1
# Nếu Redis Docker có REDIS_PASSWORD (ví dụ redis-secret-change-me), đặt khớp ở đây.
REDIS_PASSWORD=
REDIS_SOCKET_TIMEOUT=2.0

# VNStock caching (shared Redis). Set VNSTOCK_CACHE_ENABLED=false to bypass cache quickly.
VNSTOCK_CACHE_ENABLED=true
VNSTOCK_CACHE_QUOTE_TTL=45
VNSTOCK_CACHE_HISTORY_TTL=21600
VNSTOCK_CACHE_SYMBOLS_TTL=86400

# LangGraph /api/analyze — cache response in Redis (same DB as VNStock cache).
# Disable by setting ANALYZE_CACHE_ENABLED=false if you need every call to hit the LLM.
ANALYZE_CACHE_ENABLED=true
ANALYZE_CACHE_TTL=1800
# Seconds allowed for the pre-graph LLM ping; if it exceeds, /api/analyze returns a safe fallback.
LLM_HEALTH_PROBE_TIMEOUT=8

# --- Forecast job queue (RQ) ---
# Provider used inside the RQ worker when running the LangGraph analyse job.
# Keep this separate from LLM_PROVIDER so AI Insights can stay on Beeknoee
# while Forecast runs on OpenRouter (no concurrent-slot conflict).
ANALYZE_LLM_PROVIDER=openrouter
# Optional override for LANGGRAPH_LIGHT_MODE inside the worker process.
ANALYZE_LIGHT_MODE=false
# Max seconds a single job is allowed to run in the worker.
ANALYZE_JOB_TIMEOUT=420
# How long (seconds) RQ keeps the successful result in Redis for polling.
ANALYZE_JOB_RESULT_TTL=28800
# How long (seconds) RQ keeps the failed-job metadata so users can see errors.
ANALYZE_JOB_FAILURE_TTL=3600
# Informational — actual concurrency comes from how many `python worker.py` processes you run.
ANALYZE_WORKER_CONCURRENCY=1

ENVIRONMENT=development

# .NET: point AIService:BaseUrl (and optional StockAnalyst:BaseUrl) to this app, e.g. http://localhost:8000

# --- Financial report Q&A (dashboard) ---
# Backend calls POST /api/qa with base_context + source=financial_report. Run this service, e.g.:
#   uvicorn src.api.main:app --reload --port 8000
# LLM: set GEMINI_API_KEY (preferred) or BLACKBOX_API_KEY in this .env — same stack as forecast/news QA.
# StockInvestment.Api: AIService:BaseUrl (and Url) = http://localhost:8000 (or Docker host, e.g. http://host.docker.internal:8000).
# Qdrant errors are OK: .NET sends the full report snapshot in base_context; QAService can skip vector search for financial_report when base_context is present.
